model Quote {
  id                 String      @id @default(uuid())
  carrierName        String
  bidId              String      @unique
  bid                Bid         @relation(fields: [bidId], references: [bidId], onDelete: Cascade)
  freightCharges     Decimal
  originCharges      Decimal
  destinationCharges Decimal
  transitTime        Int
  validityDate       DateTime
  status             QuoteStatus
  versionNumber      Int
  isLatest           Boolean
  createdAt          DateTime    @default(now())
}

model ActivityLog {
  id            String                @id @default(uuid())
  rfqId         String
  rfq           RFQ                   @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  eventType     ActivityEventType
  eventCategory ActivityEventCategory
  actorId       String?
  actorType     ActorType
  correlationId String?
  oldValue      Json?
  newValue      Json?
  metadata      Json?
  createdAt     DateTime              @default(now())

  @@index([rfqId, createdAt])
}

model AuctionExtension {
  id          String               @id @default(uuid())
  rfqId       String
  rfq         RFQ                  @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  triggerType ExtensionTriggerType
  triggerTime DateTime
  oldEndTime  DateTime
  newEndTime  DateTime

  // ⚠ Ensure in service:
  // newEndTime <= RFQ.forcedCloseTime
}

model Notification {
  id            String           @id @default(uuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id])
  rfqId         String?
  rfq           RFQ?             @relation(fields: [rfqId], references: [id], onDelete: SetNull)
  type          NotificationType
  title         String
  message       String
  isRead        Boolean          @default(false)
  metadata      Json?
  correlationId String?
  createdAt     DateTime         @default(now())

  @@index([userId, isRead])
}
